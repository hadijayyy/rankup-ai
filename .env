# RankUp AI - Environment Variables
# Load OpenCode Go API key from Hermes config
source /home/ubuntu/.hermes/.env 2>/dev/null || true

# Fallback: uncomment and set manually if needed
# OPENCODE_GO_API_KEY=sk-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# LLM Configuration (optional overrides)
# LLM_BASE_URL=https://opencode.ai/zen/go/v1
# LLM_MODEL=deepseek-v4-flash
# LLM_TEMPERATURE=0.3
# LLM_MAX_TOKENS=4096
