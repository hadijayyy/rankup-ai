{
  "version": 2,
  "builds": [
    {
      "src": "api/index_minimal.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 10 }
    },
    {
      "src": "dashboard/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index_minimal.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/dashboard/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/static/index.html"
    }
  ]
}
